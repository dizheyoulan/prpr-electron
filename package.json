{
  "name": "prpr-electron",
  "version": "1.0.0",
  "description": "PRPR - Moebooru client built with Electron + Vue3",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "electron:dev": "powershell chcp 65001; electron-vite dev",
    "electron:build": "electron-vite build && electron-builder",
    "electron:build:portable": "electron-vite build && electron-builder --win portable",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cheerio": "^1.2.0",
    "electron-store": "^10.0.1",
    "element-plus": "^2.9.7",
    "fast-xml-parser": "^4.5.3",
    "https-proxy-agent": "^9.0.0",
    "pinia": "^2.3.1",
    "sql.js": "^1.14.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "wallpaper": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.15.17",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "sass": "^1.89.0",
    "typescript": "^5.8.3",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.10"
  }
}
