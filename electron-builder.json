{
  "appId": "com.prpr.app",
  "productName": "PRPR",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*",
    "assets/**/*"
  ],
  "win": {
    "target": ["nsis", "portable"],
    "icon": "assets/poster.ico"
  },
  "portable": {
    "artifactName": "${productName}-Portable-${version}.exe",
    "requestExecutionLevel": "user"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "assets/poster.ico"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "assets/poster.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}