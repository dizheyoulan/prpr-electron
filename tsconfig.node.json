{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "strict": true,
    "noEmit": false,
    "outDir": "dist-electron"
  },
  "include": ["electron/**/*.ts", "electron.vite.config.ts"]
}
